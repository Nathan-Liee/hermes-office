# ── Hermes API ──────────────────────────────────────────────────────
# URL of the Hermes API server (e.g., OpenAI-compatible endpoint)
HERMES_API_URL=http://localhost:8642

# API key for the Hermes API server
HERMES_API_KEY=change-me-local-dev

# Model identifier to use with the Hermes API
HERMES_MODEL=hermes-agent

# ── App server ──────────────────────────────────────────────────────
# Port the HO3D web server listens on
# PORT=3000

# Host interface to bind the server to
# HOST=127.0.0.1

# ── Auth (required for public/remote deployments) ────────────────────
# Access token required by Studio to connect
# STUDIO_ACCESS_TOKEN=

# Comma-separated list of hosts allowed to connect (e.g., "localhost,studio.example.com")
# UPSTREAM_ALLOWLIST=localhost
