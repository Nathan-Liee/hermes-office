# ── Hermes (primary runtime) ─────────────────────────────────────────
# Required: Hermes API server address and key
HERMES_API_URL=http://localhost:8642
HERMES_API_KEY=change-me-local-dev
HERMES_MODEL=hermes-agent

# Adapter listens here — HO3D connects to this WebSocket port
HERMES_ADAPTER_PORT=18789

# Browser/client gateway URL (build-time — requires `npm run build` after changes)
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:18789

# Runtime gateway URL — takes effect on restart without a rebuild.
# Use this instead of NEXT_PUBLIC_GATEWAY_URL when you want to change the
# gateway endpoint without re-running `npm run build`.
# CLAW3D_GATEWAY_URL=ws://localhost:18789
# CLAW3D_GATEWAY_TOKEN=

# Optional: tell Studio which backend that runtime gateway URL represents.
# Valid values: hermes, openclaw, demo, custom
# CLAW3D_GATEWAY_ADAPTER_TYPE=hermes

# ── OpenClaw (alternative runtime) ───────────────────────────────────
# Point CLAW3D_GATEWAY_URL at an OpenClaw Gateway WebSocket endpoint instead.
# Device approval may be needed: `openclaw devices approve --latest`

# ── Demo gateway (no runtime required) ───────────────────────────────
# Run `npm run demo-gateway` and connect HO3D to ws://localhost:18789
# DEMO_ADAPTER_PORT=18789
# If CLAW3D_GATEWAY_URL is unset, Studio can still detect this local adapter port.

# ── Debug ────────────────────────────────────────────────────────────
DEBUG=true

# ── App server ───────────────────────────────────────────────────────
# PORT=3000
# HOST=127.0.0.1

# ── Auth (required for public/remote deployments) ────────────────────
# STUDIO_ACCESS_TOKEN=

# ── Voice ────────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
